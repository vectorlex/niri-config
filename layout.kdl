// layout.kdl
layout {
  gaps 8

  center-focused-column "never"

  preset-column-widths {
    proportion 0.33333
    proportion 0.5
    proportion 0.66667
  }

  default-column-width { proportion 0.5; }

  focus-ring {
    width 1
  }

  shadow {
    on
    softness 30
    spread 5
    offset x=0 y=0
  }

  struts {
    // left 64
    // right 64
    // top 64
    // bottom 64
  }
}


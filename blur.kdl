blur {
  passes 6        // more passes = stronger blur (default: 3)
  offset 2.0      // sample distance per pass (default: 3.0)
  noise 0.01      // grain overlay (default: 0.02)
  saturation 1.2  // color saturation boost (default: 1.5)
}

/* Noctalia: blur everywhere without xray for a better look */
layer-rule {
  match namespace="^noctalia-(bar-[^\"]+|notification|dock|panel|attached-panel|osd)$"
  background-effect {
    xray false
  }
}
